rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================
    // HELPER FUNCTIONS
    // =====================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isJobMaster() {
      return isSignedIn() && getUserRole() == 'jobmaster';
    }

    function isAccountant() {
      return isSignedIn() && getUserRole() == 'accountant';
    }

    function isAdminOrJobMaster() {
      return isAdmin() || isJobMaster();
    }

    // =====================
    // USERS
    // =====================
    match /users/{uid} {
      // Any authenticated user can read profiles
      allow read: if isSignedIn();

      // Users can only create their OWN profile with role='freelancer'
      allow create: if isOwner(uid)
                    && request.resource.data.role == 'freelancer';

      // Admins can create profiles for backend users (jobmaster, accountant, admin)
      // Freelancers self-register via the public registration flow
      allow create: if isAdmin()
                    && request.resource.data.role in ['jobmaster', 'accountant', 'admin'];

      // Users can update their OWN profile but CANNOT change protected fields
      // stats, trustScore, trustBadge are managed by Cloud Functions only
      allow update: if isOwner(uid)
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'stats', 'trustScore', 'trustBadge', 'createdAt']));

      // Admins can update ANY user (including role changes)
      allow update: if isAdmin();

      // Nobody can delete users from client
      allow delete: if false;

      // User badges subcollection
      match /badges/{badgeId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // =====================
    // JOBS
    // =====================
    match /jobs/{jobId} {
      // Public: anyone can read jobs
      allow read: if true;

      // Only admins and job masters can create/update jobs
      allow create: if isAdminOrJobMaster();
      allow update: if isAdminOrJobMaster();

      // Freelancer does NOT directly update job docs.
      // Progress is auto-calculated from milestone completion.
      // All freelancer interactions go through submissions subcollection.

      allow delete: if isAdmin();

      // ---- Milestone Submissions (subcollection) ----
      match /submissions/{subId} {
        // Any authenticated user can read submissions (jobmaster/admin/freelancer)
        allow read: if isSignedIn();

        // Only the assigned freelancer can create submissions
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/jobs/$(jobId)).data.assignedTo == request.auth.uid
                      && request.resource.data.status == 'pending_review';

        // Admin/Jobmaster can update submissions (approve/reject)
        allow update: if isAdminOrJobMaster();

        // Nobody can delete submissions (audit trail)
        allow delete: if false;
      }
    }

    // =====================
    // APPLICATIONS
    // =====================
    match /applications/{appId} {
      // Authenticated users can read applications
      allow read: if isSignedIn();

      // Users can create applications with their own applicantId
      allow create: if isSignedIn()
                    && request.resource.data.applicantId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Admins and job masters can update application status
      allow update: if isAdminOrJobMaster();

      // Nobody can delete applications
      allow delete: if false;
    }

    // =====================
    // COMMENTS
    // =====================
    match /comments/{commentId} {
      // Anyone can read comments (public job discussions)
      allow read: if true;

      // Authenticated users can create comments with their own authorId
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid;

      // Users can update their own comments, admins can update any
      allow update: if isOwner(resource.data.authorId) || isAdmin();

      // Users can delete their own comments, admins can delete any
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // =====================
    // CONTRACTS
    // =====================
    match /contracts/{contractId} {
      // Authenticated users can read (workers see their own via queries)
      allow read: if isSignedIn();

      // Only admins and accountants can create/update contracts
      allow create: if isAdmin() || isAccountant();
      allow update: if isAdmin() || isAccountant()
                    || (isSignedIn() && resource.data.partyB.uid == request.auth.uid);

      allow delete: if isAdmin();
    }

    // =====================
    // PAYMENTS
    // =====================
    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isAccountant() || isJobMaster();
      allow update: if isAdmin() || isAccountant();
      allow delete: if false;
    }

    // =====================
    // CONVERSATIONS & MESSAGES
    // =====================
    match /conversations/{convId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // =====================
    // NOTIFICATIONS
    // =====================
    match /notifications/{notiId} {
      allow read: if isSignedIn()
                  && resource.data.recipientId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.recipientId == request.auth.uid;
      // Any authenticated user can create notifications
      // (freelancers notify jobmasters on milestone submission, etc.)
      allow create: if isSignedIn();
      allow delete: if false;
    }

    // =====================
    // SYSTEM CONFIG (Admin-only)
    // =====================
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =====================
    // BANNERS (Admin write, public read for homepage)
    // =====================
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =====================
    // TESTIMONIALS (Admin write, public read for homepage)
    // =====================
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =====================
    // LEADERBOARD (Public read)
    // =====================
    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =====================
    // BADGE DEFINITIONS
    // =====================
    match /badge_definitions/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =====================
    // AUDIT LOGS
    // =====================
    match /auditLogs/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();

      // Any authenticated user can write (logging their own actions)
      allow create: if isSignedIn();

      // Nobody can update or delete audit logs
      allow update, delete: if false;
    }

    // =====================
    // REVIEWS (Rating/Review System)
    // =====================
    match /reviews/{reviewId} {
      // Anyone can read reviews (public)
      allow read: if true;

      // Authenticated users can create reviews with their own reviewerId
      allow create: if isSignedIn()
                    && request.resource.data.reviewerId == request.auth.uid;

      // Admins can update/delete reviews (moderation)
      allow update, delete: if isAdmin();
    }

    // =====================
    // DISPUTES
    // =====================
    match /disputes/{disputeId} {
      // Participants and admins can read disputes
      allow read: if isSignedIn()
                  && (request.auth.uid in resource.data.participants
                      || isAdmin());

      // Authenticated users can create disputes (with themselves as initiator)
      allow create: if isSignedIn()
                    && request.resource.data.initiatorId == request.auth.uid;

      // Only admins can update disputes (resolution)
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid in resource.data.participants);

      // Nobody can delete disputes
      allow delete: if false;
    }

    // =====================
    // JOB INVITATIONS
    // =====================
    match /invitations/{invId} {
      // Single document read: inviter and invitee only
      allow get: if isSignedIn()
                  && (resource.data.jobmasterId == request.auth.uid
                      || resource.data.freelancerId == request.auth.uid
                      || isAdmin());

      // List queries: allow authenticated users (query filters by freelancerId/jobmasterId)
      allow list: if isSignedIn();

      // Job masters and admins can create invitations
      allow create: if isAdminOrJobMaster();

      // Invited freelancer can update (accept/decline)
      allow update: if isSignedIn()
                    && resource.data.freelancerId == request.auth.uid;

      allow delete: if false;
    }

    // =====================
    // CHALLENGES (Seasonal)
    // =====================
    match /challenges/{challengeId} {
      // Public read
      allow read: if true;

      // Only admins can manage challenges
      allow write: if isAdmin();
    }

    // =====================
    // INVOICES
    // =====================
    match /invoices/{invoiceId} {
      // Authenticated users can read their own invoices
      allow read: if isSignedIn();

      // Admins and accountants can create/update invoices
      allow create: if isAdmin() || isAccountant();
      allow update: if isAdmin() || isAccountant();
      allow delete: if false;
    }


  }
}
