rules_version = '2';

// Storage rules for VAA JOB
service firebase.storage {
  match /b/{bucket}/o {
    // Avatar uploads — users can only write to their own folder
    match /avatars/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // 2MB max
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // KYC — CCCD front/back images (5MB max, images only)
    match /kyc/{userId}/{filename} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || request.auth.token.role == 'admin'
            || request.auth.token.role == 'accountant');
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // Certificate images — user's own, optional
    match /certificates/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // Signature images — freelancer's own drawn/uploaded signature
    match /signatures/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // Contracts — generated by Cloud Functions (Admin SDK bypasses these rules)
    match /contracts/{contractId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Fallback for all other authenticated reads/writes
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
