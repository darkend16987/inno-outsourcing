rules_version = '2';

// Storage rules for VAA JOB
service firebase.storage {
  match /b/{bucket}/o {
    // Avatar uploads — users can only write to their own folder
    match /avatars/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // 2MB max
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /{allPaths=**} {
      // Allow read for authenticated users (to view PDFs, avatars, etc.)
      allow read: if request.auth != null;
      
      // Allow write only if authenticated
      // Note: Cloud Functions (Admin SDK) bypasses these rules.
      allow write: if request.auth != null;
    }
    
    match /contracts/{contractId} {
       allow read: if request.auth != null;
       // Admin SDK in Cloud Functions will handle creation
       allow write: if false; 
    }
  }
}
