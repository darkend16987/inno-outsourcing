rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──── Helpers ────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }
    function hasAnyRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }

    // ──── USERS ────
    match /users/{userId} {
      // Public fields only: displayName, photoURL, role, specialties, currentLevel, stats, bio
      // Anyone can read public profile
      allow read: if true;

      // User can create their own profile (with fixed role = freelancer)
      allow create: if isUser(userId)
        && request.resource.data.role == 'freelancer';

      // User can update own profile BUT cannot change role or status
      allow update: if (isUser(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status)
        || hasRole('admin');

      allow delete: if hasRole('admin');

      // Private subcollection — only owner + admin can access
      match /private/{docId} {
        allow read, write: if isUser(userId) || hasRole('admin');
      }

      // Certificates subcollection
      match /certificates/{certId} {
        allow read: if isUser(userId) || hasAnyRole(['admin', 'jobmaster']);
        allow create, update: if isUser(userId) || hasRole('admin');
        allow delete: if hasRole('admin');
      }

      // Portfolio subcollection
      match /portfolio/{itemId} {
        allow read: if true;
        allow create, update: if isUser(userId);
        allow delete: if isUser(userId) || hasRole('admin');
      }

      // Badges subcollection
      match /badges/{badgeId} {
        allow read: if true;
        allow write: if hasRole('admin');
      }
    }

    // ──── JOBS ────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if hasAnyRole(['admin', 'jobmaster']);
      allow update: if hasAnyRole(['admin', 'jobmaster']);
      allow delete: if hasRole('admin');

      // Job comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
        allow delete: if hasRole('admin') || (isAuthenticated() && resource.data.authorId == request.auth.uid);
      }

      // Progress updates subcollection
      match /progressUpdates/{updateId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if hasAnyRole(['admin', 'jobmaster']);
        allow delete: if hasRole('admin');
      }

      // Deliverables subcollection
      match /deliverables/{delivId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if hasAnyRole(['admin', 'jobmaster']);
        allow delete: if hasRole('admin');
      }
    }

    // ──── APPLICATIONS ────
    match /applications/{applicationId} {
      allow read: if (isAuthenticated() && resource.data.freelancerId == request.auth.uid)
        || hasAnyRole(['admin', 'jobmaster']);

      // Freelancer can apply — must match own UID
      allow create: if isAuthenticated()
        && request.resource.data.freelancerId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if hasAnyRole(['admin', 'jobmaster']);
      allow delete: if hasRole('admin');
    }

    // ──── CONTRACTS ────
    match /contracts/{contractId} {
      allow read: if (isAuthenticated() && resource.data.partyB.uid == request.auth.uid)
        || hasAnyRole(['admin', 'jobmaster', 'accountant']);
      allow create: if hasAnyRole(['admin', 'jobmaster']);
      // Freelancer can update only for signing (limited fields)
      allow update: if (isAuthenticated() && resource.data.partyB.uid == request.auth.uid)
        || hasAnyRole(['admin', 'jobmaster', 'accountant']);
      allow delete: if hasRole('admin');
    }

    // ──── PAYMENTS (was "transactions" — FIXED) ────
    match /payments/{paymentId} {
      allow read: if (isAuthenticated() && resource.data.workerId == request.auth.uid)
        || hasAnyRole(['admin', 'accountant', 'jobmaster']);
      allow create, update: if hasAnyRole(['accountant', 'admin']);
      allow delete: if hasRole('admin');
    }

    // ──── CONVERSATIONS ────
    match /conversations/{convId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if hasRole('admin');

      // Messages subcollection
      match /messages/{msgId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow update, delete: if hasRole('admin');
      }
    }

    // ──── NOTIFICATIONS ────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if hasAnyRole(['admin', 'jobmaster', 'accountant']);
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // ──── LEADERBOARD ────
    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ──── TESTIMONIALS ────
    match /testimonials/{itemId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ──── BANNERS ────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ──── SYSTEM CONFIG ────
    match /system_config/{configId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ──── BADGE DEFINITIONS ────
    match /badge_definitions/{badgeId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ──── REVIEWS ────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if hasRole('admin');
    }

    // ──── DISPUTES ────
    match /disputes/{disputeId} {
      allow read: if isAuthenticated()
        && (request.auth.uid in resource.data.participants || hasRole('admin'));
      allow create: if isAuthenticated()
        && request.resource.data.initiatorId == request.auth.uid;
      allow update: if hasRole('admin')
        || (isAuthenticated() && request.auth.uid in resource.data.participants);
      allow delete: if false;
    }

    // ──── AUDIT LOGS ────
    match /auditLogs/{logId} {
      allow read: if hasRole('admin');
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ──── COMMENTS (top-level) ────
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow delete: if hasRole('admin') || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }
  }
}
